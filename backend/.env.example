# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

PORT=5000

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=stocknest
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT - use a long random string, keep it secret
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long
JWT_EXPIRES_IN=7d

# Firebase
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# SendGrid — Email alerts for low stock / out-of-stock events
# Get your key at: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Fallback alert recipient (used when an item has no supplier_email set)
ALERT_RECIPIENT_EMAIL=admin@yourdomain.com
